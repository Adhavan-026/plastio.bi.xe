{
  "name": "plastio.bi.xe",
  "version": "0.1.0",
  "private": true,
  "description": "clickOne — multi-tenant billing for Indian agro and tyre shops, cloud and offline desktop.",
  "author": "clickOne",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "seed:production-demo": "tsx prisma/seed-production-demo.ts",
